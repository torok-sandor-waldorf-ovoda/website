{
  "name": "waldorf-ovi",
  "version": "1.0.0",
  "description": "Török Sándor Waldorf Óvoda – 11ty + MDX static site",
  "type": "module",
  "scripts": {
    "build": "eleventy",
    "start": "eleventy --serve",
    "dev": "eleventy --serve & python3 -m http.server 3001 --directory _site 2>/dev/null & wait",
    "clean": "rm -rf _site"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@mdx-js/mdx": "^3.1.0",
    "@mdx-js/node-loader": "^3.1.1",
    "pasito": "^0.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
