<style>
  .c-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: var(--sp-6);
    margin-top: calc(var(--sp-4) * -1);
  }

  @media (max-width: 768px) {
    .c-cards {
      grid-template-columns: 1fr;
    }
  }
</style>

<div webc:root="override" class="c-cards"><slot></slot></div>
